# ----------------------------------------------------------------------------
# ProductValidation MCP — environment variables
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# ----------------------------------------------------------------------------

# Serper (Google Search) — 2,500 free searches/mo
# Get at: https://serper.dev
# Powers: web search, competitor lookup, weakness mapping, AND Reddit discussions
# (via `site:reddit.com` — no separate Reddit credentials needed).
SERPER_API_KEY=

# Product Hunt API v2
# Apply at: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_KEY=

# GitHub Personal Access Token (no scopes needed for public reads)
# Generate at: https://github.com/settings/tokens
# Needed by upcoming estimate_demand_signals tool.
GITHUB_TOKEN=
